RewriteEngine On

# ===============================
# ADMIN ROUTING
# ===============================
RewriteRule ^admin/?$ admin/login.php [L]
RewriteRule ^admin/login/?$ admin/login.php [L]
RewriteRule ^admin/dashboard/?$ admin/dashboard.php [L]

# ===============================
# PUBLIC ROUTING
# ===============================
RewriteRule ^$ index.php [L]

RewriteRule ^profil/?$ profile.php [L]
RewriteRule ^visi-misi/?$ visi-misi.php [L]
RewriteRule ^ppdb/?$ ppdb.php [L]
RewriteRule ^skill-passport/?$ skill-passport.php [L]

# Jurusan
RewriteRule ^titl/?$ titl.php [L]
RewriteRule ^tei/?$ tei.php [L]
RewriteRule ^tm/?$ tm.php [L]
RewriteRule ^tkro/?$ tkro.php [L]
RewriteRule ^tsm/?$ tsm.php [L]
RewriteRule ^tki/?$ tki.php [L]
RewriteRule ^perhotelan/?$ perhotelan.php [L]

# News
RewriteRule ^berita/?$ news.php [L]
RewriteRule ^berita/([a-zA-Z0-9-]+)/?$ news-detail.php?slug=$1 [L]

# ===============================
# PROTECT FILES
# ===============================
RewriteRule ^(config|core)/ - [F,L]
